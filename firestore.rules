
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir lectura de usuarios para el proceso de login (Genkit Flow)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reglas maestras para el resto de las colecciones
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
