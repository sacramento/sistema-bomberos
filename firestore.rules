rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- REGLAS DE EMERGENCIA PARA RESTAURAR VISIBILIDAD ---
    // Se permite el acceso a las colecciones principales mientras se sincroniza 
    // el sistema de autenticación con Firebase Auth.
    
    match /materials/{m} { allow read, write: if true; }
    match /material_requests/{r} { allow read, write: if true; }
    match /users/{u} { allow read, write: if true; }
    match /firefighters/{f} { allow read, write: if true; }
    match /vehicles/{v} { allow read, write: if true; }
    match /cascade_charges/{c} { allow read, write: if true; }
    match /cascade_system_charges/{cs} { allow read, write: if true; }
    match /sessions/{s} { allow read, write: if true; }
    match /workshops/{w} { allow read, write: if true; }
    match /courses/{co} { allow read, write: if true; }
    match /weeks/{wk} { allow read, write: if true; }
    match /tasks/{t} { allow read, write: if true; }
    match /maintenance_records/{mr} { allow read, write: if true; }
    match /repair_records/{rr} { allow read, write: if true; }
    match /clothing/{cl} { allow read, write: if true; }
    match /general_inventory/{gi} { allow read, write: if true; }
    match /audit_logs/{al} { allow read, write: if true; }

    match /{path=**}/leaves/{leaveId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}