rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FUEGO REGISTRO - SECURITY RULES DOCUMENTATION
     * 
     * Core Philosophy:
     * This ruleset implements a Role-Based Access Control (RBAC) model combined with Ownership
     * verification. The application distinguishes between Administrators, Operators, and Assistants
     * to manage firehouse operations, training, and leave requests.
     * 
     * Data Structure:
     * - Master Lookup Data: Top-level collections (firehouses, ranks, etc.) accessible to all 
     *   authenticated users but manageable only by Administrators.
     * - User Profiles: Managed at /app_users/{uid}, serving as the source of truth for roles.
     * - Operational Data: Training sessions and firefighter profiles.
     * - Hierarchical Requests: Leave requests are nested under firefighters (/firefighters/{id}/leaves/{id}).
     * 
     * Key Security Decisions:
     * - Denormalization: The 'role' is stored directly in the 'AppUser' document to simplify 
     *   authorization. Rules use get() calls to this document to verify permissions.
     * - Prototyping Flexibility: Logic enforces "Who can access" and "Relational Links" 
     *   (e.g., recordedByUserId) but does not strictly validate the internal content schema.
     * - Admin Oversight: To resolve the "missing requests" issue, read access to leave 
     *   subcollections is granted to all signed-in users (restricted by role in the UI), 
     *   ensuring Administrators can perform collection group queries for "PENDING" statuses.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/app_users/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return isSignedIn() && getRole() == role;
    }

    function isAdmin() {
      return hasRole('Administrator');
    }

    function isOperator() {
      return hasRole('Operator');
    }

    function isAssistant() {
      return hasRole('Assistant');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // The 'isExistingOwner' function was removed because it was unused
    // and incorrectly referenced the 'resource' variable in a global helper function scope.

    // --- COLLECTION RULES ---

    /**
     * @description Rules for Master Lookup data: Firehouses, Ranks, Specializations, and Leave Types.
     * @path /firehouses/{id}, /ranks/{id}, /specializations/{id}, /leave_types/{id}
     * @allow Authenticated user (get, list), Administrator (create, update, delete)
     * @deny Unauthenticated user (any), Non-admin (write)
     * @principle Public Read for internal lookups with Admin-only data management.
     */
    match /firehouses/{firehouseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /ranks/{rankId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /specializations/{specializationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /leave_types/{leaveTypeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for individual firefighter profiles.
     * @path /firefighters/{firefighterId}
     * @allow Authenticated user (get, list), Administrator (create, update, delete)
     * @deny Non-admin (write)
     * @principle Role-based management of personnel records.
     */
    match /firefighters/{firefighterId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      /**
       * @description Rules for leave requests nested under a firefighter.
       * @path /firefighters/{firefighterId}/leaves/{leaveId}
       * @allow Administrator or Assistant (create, update, delete), Authenticated (get, list)
       * @deny Assistant trying to change 'recordedByUserId' on update.
       * @principle Ensures audit trail integrity and administrative oversight.
       */
      match /leaves/{leaveId} {
        allow get, list: if isSignedIn();
        allow create: if (isAdmin() || isAssistant()) && request.resource.data.recordedByUserId == request.auth.uid;
        allow update: if resource != null && (isAdmin() || (isAssistant() && request.resource.data.recordedByUserId == resource.data.recordedByUserId));
        allow delete: if resource != null && isAdmin();
      }
    }

    /**
     * @description Rules for application user profiles.
     * @path /app_users/{appUserId}
     * @allow Self (get, update, create), Administrator (all)
     * @deny Different user (get, update), Non-admin (list)
     * @principle Restricts user data to the owner and administrators.
     */
    match /app_users/{appUserId} {
      allow get: if isOwner(appUserId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(appUserId) && request.resource.data.id == appUserId;
      allow update: if resource != null && (isOwner(appUserId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if resource != null && isAdmin();
    }

    /**
     * @description Rules for training sessions and their participants.
     * @path /training_sessions/{trainingSessionId}
     * @allow Authenticated user (get, list), Administrator or Operator (create, update, delete)
     * @deny Non-operator/Non-admin (write)
     * @principle Operators manage field activities while others maintain visibility.
     */
    match /training_sessions/{trainingSessionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isOperator();

      match /participants/{participantId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin() || isOperator();
      }
    }

    /**
     * @description Support for Collection Group queries for leaves (Admin dashboard).
     * @path /{path=**}/leaves/{leaveId}
     * @allow Administrator (list)
     * @principle Enables administrators to query all leave requests across the entire database.
     */
    match /{path=**}/leaves/{leaveId} {
      allow get, list: if isAdmin() || isAssistant();
    }

  }
}