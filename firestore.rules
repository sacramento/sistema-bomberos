rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir lectura de usuarios para el proceso de login
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reglas maestras para operatividad durante desarrollo
    // Se requiere que el usuario esté autenticado en Firebase (vía sync anónimo)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
