rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is authenticated.
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get the role of the currently signed-in user.
    function getUserRole() {
      // The user's role is stored in the 'users' collection with their UID as the document ID.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check if the user is an Administrator.
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'Administrador';
    }
    
    // Helper function to check if the user is an Operator.
    function isOperator() {
      return isAuthenticated() && getUserRole() == 'Operador';
    }

    // Helper function to check if the user is an Ayudantia.
    function isAyudantia() {
      return isAuthenticated() && getUserRole() == 'Ayudantía';
    }

    // Users Collection: Only Admins can manage users.
    match /users/{userId} {
      allow read, write: if isAdmin();
    }

    // Firefighters Collection: Admins can manage firefighters. Other authenticated users can read the list.
    match /firefighters/{firefighterId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Sessions (Classes) Collection: 
    // Admins/Operators can manage sessions. 
    // Authenticated users can read session data.
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || isOperator();
    }
    
    // Leaves (Licencias) Collection: 
    // Admins/Ayudantia can manage leaves.
    // Other roles can't access this data directly.
    match /leaves/{leaveId} {
      allow read, create, update, delete: if isAdmin() || isAyudantia();
    }
    
    // Courses Collection:
    // Admins/Ayudantia can manage courses.
    // Other roles can't access this data directly.
    match /courses/{courseId} {
       allow read, create, update, delete: if isAdmin() || isAyudantia();
    }
  }
}
