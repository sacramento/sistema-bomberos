
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Función para verificar el rol del usuario autenticado
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdministrator() {
      return isSignedIn() && getUserRole() == 'Administrador';
    }

    function isOperator() {
      return isSignedIn() && getUserRole() == 'Operador';
    }
    
    function isAyudantia() {
      return isSignedIn() && getUserRole() == 'Ayudantía';
    }

    // Reglas para la colección 'users'
    match /users/{userId} {
      // PERMITE el inicio de sesión. Cualquiera puede intentar obtener un usuario por su ID (legajo).
      // Esto es seguro porque la contraseña se verifica en el backend (genkit flow).
      allow get: if true;
      
      // SOLO los administradores pueden listar, crear, editar o eliminar usuarios.
      allow list, create, update, delete: if isAdministrator();
    }

    // Reglas para la colección 'firefighters'
    match /firefighters/{firefighterId} {
      // Administradores tienen acceso total.
      allow read, write: if isAdministrator();
      
      // Operadores y Ayudantía solo pueden leer la información de los bomberos.
      allow read: if isOperator() || isAyudantia();
    }

    // Reglas para la colección 'sessions' (clases)
    match /sessions/{sessionId} {
      // Administradores y Operadores tienen acceso total para gestionar clases.
      allow read, write: if isAdministrator() || isOperator();
    }
    
    // Reglas para la colección 'leaves' (licencias)
    match /leaves/{leaveId} {
        // Administradores y Ayudantía pueden gestionar licencias.
        allow read, write: if isAdministrator() || isAyudantia();
    }
    
    // Reglas para la colección 'courses' (cursos externos)
    match /courses/{courseId} {
       // Administradores y Ayudantía pueden gestionar los cursos.
       allow read, write: if isAdministrator() || isAyudantia();
    }
  }
}
