rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Función para obtener el rol del usuario que hace la solicitud.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Función para verificar si el usuario está autenticado.
    function isSignedIn() {
      return request.auth != null;
    }

    // Reglas para la colección 'users'
    match /users/{userId} {
      // PERMITIR LOGIN: Cualquiera puede leer un documento de usuario específico para el proceso de login.
      // Esto es seguro porque solo se obtiene el doc si se conoce el ID (legajo). La contraseña se valida en el backend.
      allow get: if true;

      // SOLO ADMINS: Listar, crear, actualizar y borrar usuarios.
      allow list, create, update, delete: if isSignedIn() && getUserRole() == 'Administrador';
    }
    
    // Reglas para 'firefighters'
    match /firefighters/{docId} {
      // SOLO ADMINS: Pueden realizar todas las operaciones (CRUD).
      allow read, write: if isSignedIn() && getUserRole() == 'Administrador';
    }

    // Reglas para 'sessions' (Clases)
    match /sessions/{docId} {
      // ADMINS Y OPERADORES: Pueden leer, crear, actualizar y borrar clases.
      allow read, write: if isSignedIn() && (getUserRole() == 'Administrador' || getUserRole() == 'Operador');
    }

    // Reglas para 'leaves' (Licencias)
    match /leaves/{docId} {
      // ADMINS Y AYUDANTÍA: Pueden leer, crear, actualizar y borrar licencias.
      allow read, write: if isSignedIn() && (getUserRole() == 'Administrador' || getUserRole() == 'Ayudantía');
    }

    // Reglas para 'courses' (Cursos Externos)
    match /courses/{docId} {
      // ADMINS Y AYUDANTÍA: Pueden leer, crear, actualizar y borrar cursos.
      allow read, write: if isSignedIn() && (getUserRole() == 'Administrador' || getUserRole() == 'Ayudantía');
    }
  }
}
