
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if the user has a specific role in a module
    function hasRole(module, requiredRoles) {
      if (request.auth == null) return false;
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      if (!userDoc.exists) return false;
      
      let userRoles = userDoc.data.roles;
      let userGlobalRole = userDoc.data.role;
      
      if (userGlobalRole == 'Master') {
        return true;
      }
      
      if (module == 'asistencia') {
        return userRoles.asistencia in requiredRoles;
      }
      if (module == 'aspirantes') {
        return userRoles.aspirantes in requiredRoles;
      }
      if (module == 'semanas') {
        return userRoles.semanas in requiredRoles;
      }
      if (module == 'movilidad') {
        return userRoles.movilidad in requiredRoles;
      }
      if (module == 'materiales') {
        return userRoles.materiales in requiredRoles;
      }
      if (module == 'servicios') {
        return userRoles.servicios in requiredRoles;
      }
      if (module == 'cascada') {
        return userRoles.cascada in requiredRoles;
      }
      // For global entities like 'users'
      if (module == 'general') {
         return userGlobalRole in requiredRoles;
      }
      
      return false;
    }

    // --- GENERAL RULES ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- AUTHENTICATED ACCESS ---
    match /databases/{database}/documents {
    
      // USERS: Only Master can manage users
      match /users/{userId} {
        allow read, write: if hasRole('general', ['Master']);
      }
      
      // FIREFIGHTERS: Managed by Asistencia Admins/Oficiales
      match /firefighters/{docId} {
        allow read: if request.auth != null;
        allow write: if hasRole('asistencia', ['Administrador', 'Oficial']);
      }

      // SESSIONS & ATTENDANCE
      match /sessions/{sessionId} {
        allow read: if request.auth != null;
        allow create, update, delete: if hasRole('asistencia', ['Administrador', 'Oficial', 'Instructor']);
      }
      
      match /aspirantes-sessions/{sessionId} {
        allow read: if request.auth != null;
        allow create, update, delete: if hasRole('aspirantes', ['Administrador', 'Oficial', 'Instructor']);
      }

      match /workshops/{workshopId} {
        allow read: if request.auth != null;
        allow create, update, delete: if hasRole('asistencia', ['Administrador', 'Oficial', 'Instructor']);
      }
      
      match /aspirantes-workshops/{workshopId} {
        allow read: if request.auth != null;
        allow create, update, delete: if hasRole('aspirantes', ['Administrador', 'Oficial', 'Instructor']);
      }
      
      match /leaves/{leaveId} {
         allow read: if hasRole('asistencia', ['Administrador', 'Oficial', 'Ayudantía']);
         allow write: if hasRole('asistencia', ['Administrador', 'Ayudantía']);
      }
      
      match /courses/{courseId} {
        allow read: if hasRole('asistencia', ['Administrador', 'Oficial', 'Ayudantía']);
        allow write: if hasRole('asistencia', ['Administrador', 'Ayudantía']);
      }

      match /weeks/{weekId} {
        allow read: if request.auth != null;
        allow write: if hasRole('semanas', ['Administrador']);
        allow update: if hasRole('semanas', ['Administrador', 'Encargado']);
      }

      match /tasks/{taskId} {
        allow read: if request.auth != null;
        allow write: if hasRole('semanas', ['Administrador', 'Encargado']);
      }

      match /vehicles/{vehicleId} {
        allow read: if request.auth != null;
        allow create, delete: if hasRole('movilidad', ['Administrador']);
        allow update: if hasRole('movilidad', ['Administrador']) || 
                       (hasRole('movilidad', ['Encargado Móvil']) && resource.data.encargadoIds.hasAny(request.auth.uid));
      }
      
      match /maintenance_items/{itemId} {
        allow read: if request.auth != null;
        allow write: if hasRole('movilidad', ['Administrador']);
      }

      match /maintenance_records/{recordId} {
        allow read: if request.auth != null;
        allow write: if hasRole('movilidad', ['Administrador', 'Encargado Móvil']);
      }
      
      match /repair_records/{recordId} {
        allow read: if request.auth != null;
        allow write: if hasRole('movilidad', ['Administrador', 'Oficial', 'Encargado Móvil']);
      }
      
      match /spare_parts/{partId} {
        allow read: if request.auth != null;
        allow write: if hasRole('movilidad', ['Administrador']);
      }
      
      // MATERIALS & REQUESTS
      match /materials/{materialId} {
        allow read: if request.auth != null;
        allow write: if hasRole('materiales', ['Administrador', 'Oficial', 'Encargado']);
      }

      match /material_requests/{requestId} {
        allow read, update, delete: if hasRole('materiales', ['Administrador']);
        allow create: if hasRole('materiales', ['Administrador', 'Oficial', 'Encargado']);
      }

      match /drivers/{driverId} {
        allow read: if request.auth != null;
        allow write: if hasRole('movilidad', ['Administrador']);
      }
      
      match /services/{serviceId} {
        allow read: if hasRole('servicios', ['Administrador', 'Oficial']);
        allow write: if hasRole('servicios', ['Administrador']);
      }

      match /audit_logs/{logId} {
        allow read: if hasRole('general', ['Master']);
        allow write: if false; 
      }

      match /cascade_charges/{chargeId} {
        allow read: if request.auth != null;
        allow write: if hasRole('cascada', ['Administrador', 'Encargado', 'Bombero']);
      }
    }
  }
}
