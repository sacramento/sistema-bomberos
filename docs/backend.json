
{
  "entities": {
    "Material": {
      "title": "Material",
      "type": "object",
      "properties": {
        "codigo": { "type": "string" },
        "nombre": { "type": "string" },
        "categoryId": { "type": "string" },
        "subCategoryId": { "type": "string" },
        "itemTypeId": { "type": "string" },
        "cuartel": { "type": "string" },
        "estado": { "type": "string", "enum": ["En Servicio", "Fuera de Servicio"] },
        "condicion": { "type": "string", "enum": ["Bueno", "Regular", "Malo"] }
      }
    },
    "MaterialRequest": {
      "title": "MaterialRequest",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "type": { "type": "string", "enum": ["UPDATE", "DELETE"] },
        "requestedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Vehicle": {
      "title": "Vehicle",
      "type": "object",
      "properties": {
        "numeroMovil": { "type": "string" },
        "marca": { "type": "string" },
        "modelo": { "type": "string" },
        "cuartel": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/materials/{id}": { "schema": "Material", "description": "Inventario de equipos" },
    "/material_requests/{id}": { "schema": "MaterialRequest", "description": "Solicitudes de cambio" },
    "/vehicles/{id}": { "schema": "Vehicle", "description": "Flota vehicular" },
    "/users/{id}": { "schema": "object", "description": "Perfiles de usuario" },
    "/firefighters/{id}": { "schema": "object", "description": "Roster de bomberos" }
  }
}
