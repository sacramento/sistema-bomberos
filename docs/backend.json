
{
  "entities": {
    "Material": {
      "title": "Material",
      "type": "object",
      "properties": {
        "codigo": { "type": "string" },
        "nombre": { "type": "string" },
        "categoryId": { "type": "string" },
        "subCategoryId": { "type": "string" },
        "itemTypeId": { "type": "string" },
        "cuartel": { "type": "string" },
        "estado": { "type": "string" },
        "condicion": { "type": "string" },
        "ubicacion": { "type": "object" }
      }
    },
    "MaterialRequest": {
      "title": "MaterialRequest",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "type": { "type": "string", "enum": ["UPDATE", "DELETE"] },
        "requestedAt": { "type": "string", "format": "date-time" },
        "materialId": { "type": "string" },
        "requestedById": { "type": "string" }
      }
    },
    "Vehicle": {
      "title": "Vehicle",
      "type": "object",
      "properties": {
        "numeroMovil": { "type": "string" },
        "marca": { "type": "string" },
        "modelo": { "type": "string" },
        "cuartel": { "type": "string" },
        "kilometraje": { "type": "number" },
        "status": { "type": "string", "enum": ["Operativo", "No operativo", "Fuera de Dotación"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/materials/{id}": { "schema": "Material", "description": "Inventario de equipos" },
    "/material_requests/{id}": { "schema": "MaterialRequest", "description": "Solicitudes de cambio de materiales" },
    "/vehicles/{id}": { "schema": "Vehicle", "description": "Flota vehicular" },
    "/users/{id}": { "schema": "object", "description": "Perfiles de usuario" },
    "/firefighters/{id}": { "schema": "object", "description": "Roster de bomberos" },
    "/audit_logs/{id}": { "schema": "object", "description": "Bitácora de auditoría" },
    "/clothing/{id}": { "schema": "object", "description": "Inventario de ropa personal" },
    "/general_inventory/{id}": { "schema": "object", "description": "Inventario de muebles y útiles" },
    "/cascade_charges/{id}": { "schema": "object", "description": "Cargas de tubos ERA" },
    "/cascade_system_charges/{id}": { "schema": "object", "description": "Cargas sistema cascada" }
  }
}
